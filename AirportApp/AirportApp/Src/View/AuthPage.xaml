<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.Src.View.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AirportApp.Src.View"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="White">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">

            <!-- Title and subtitle bound to ViewModel (previously set in code-behind) -->
            <TextBlock Text="{x:Bind ViewModel.TitleText, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#2bb8c0" HorizontalAlignment="Center"/>
            <TextBlock Text="{x:Bind ViewModel.SubtitleText, Mode=OneWay}" FontSize="16" Foreground="Gray" HorizontalAlignment="Center"/>

            <!-- Email: two-way bound to ViewModel -->
            <TextBox x:Name="emailInput" PlaceholderText="Email" Width="300" 
                     Text="{x:Bind ViewModel.EmailText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     InputScope="EmailSmtpAddress" />

            <!-- Username/Phone: visibility bound to IsRegisterFieldsVisible -->
            <TextBox x:Name="usernameInput" PlaceholderText="Username" Width="300" 
                     Text="{x:Bind ViewModel.UsernameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{x:Bind ViewModel.IsRegisterFieldsVisible, Mode=OneWay}" />
            <TextBox x:Name="phoneInput" PlaceholderText="Phone Number" Width="300" 
                     Text="{x:Bind ViewModel.PhoneText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     InputScope="TelephoneNumber"
                     Visibility="{x:Bind ViewModel.IsRegisterFieldsVisible, Mode=OneWay}" />

            <!-- Password (PasswordBox doesn't support two-way binding, synced in code-behind) -->
            <PasswordBox x:Name="passwordInput" PlaceholderText="Password" Width="300" 
                         PasswordChanged="Password_PasswordChanged" />

            <!-- Action button: label and command bound to ViewModel -->
            <Button Content="{x:Bind ViewModel.ActionButtonLabel, Mode=OneWay}" 
                    Command="{x:Bind ViewModel.ActionCommand}"
                    Background="#2bb8c0" Foreground="White" 
                    Width="300" Height="40" CornerRadius="8" 
                    FontWeight="Bold" Margin="0,10,0,0"
                    HorizontalAlignment="Center" HorizontalContentAlignment="Center"/>

            <!-- Toggle link: labels bound to ViewModel, command handles mode switch -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5" Margin="0,10,0,0">
                <TextBlock Text="{x:Bind ViewModel.TogglePromptLabel, Mode=OneWay}" VerticalAlignment="Center" Foreground="Gray"/>
                <HyperlinkButton Content="{x:Bind ViewModel.ToggleButtonLabel, Mode=OneWay}" 
                                 Command="{x:Bind ViewModel.ToggleModeCommand}"
                                 Foreground="#2bb8c0" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
