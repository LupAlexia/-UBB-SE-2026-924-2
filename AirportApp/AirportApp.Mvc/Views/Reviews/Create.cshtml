@model AirportApp.ClassLibrary.Entity.Domain.Review

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Review</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" asp-route-userId="@ViewBag.UserId">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Message" class="control-label"></label>
                <input asp-for="Message" class="form-control" />
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DutyFreeRating" class="control-label"></label>
                <input asp-for="DutyFreeRating" class="form-control" />
                <span asp-validation-for="DutyFreeRating" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FlightExperienceRating" class="control-label"></label>
                <input asp-for="FlightExperienceRating" class="form-control" />
                <span asp-validation-for="FlightExperienceRating" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StaffFriendlinessRating" class="control-label"></label>
                <input asp-for="StaffFriendlinessRating" class="form-control" />
                <span asp-validation-for="StaffFriendlinessRating" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CleanlinessRating" class="control-label"></label>
                <input asp-for="CleanlinessRating" class="form-control" />
                <span asp-validation-for="CleanlinessRating" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}