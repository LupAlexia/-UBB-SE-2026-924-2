@model AirportApp.ClassLibrary.Entity.Domain.FlightTicket

@{
    ViewData["Title"] = "Ticket Details";
    var userId = ViewBag.UserId as int?;
}

<h1>Ticket Details</h1>

<div>
    <h4>FlightTicket</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Seat)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Seat)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PassengerFirstName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PassengerFirstName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PassengerLastName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PassengerLastName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PassengerEmail)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PassengerEmail)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PassengerPhone)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PassengerPhone)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" asp-route-userId="@userId">Edit</a> |
    <a asp-action="Index" asp-route-userId="@userId">Back to List</a>
</div>
